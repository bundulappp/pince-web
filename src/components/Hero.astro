---
import { Image } from "astro:assets";
import heroImage from "../assets/house1.jpg";
---

<section
  class="relative h-screen flex flex-col justify-center items-center text-center px-4 sm:px-6 overflow-hidden"
>
  <div class="absolute inset-0 -z-10">
    <Image
      src={heroImage}
      alt="Pince Apartman"
      class="w-full h-full object-cover"
    />
    <div
      class="absolute inset-0 bg-gradient-to-b from-amber-900/50 via-stone-800/30 to-stone-900/60"
    >
    </div>
  </div>

  <h1
    class="text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-bold mb-4 sm:mb-6 text-white hero-title opacity-0"
  >
    Pince Apartman
  </h1>

  <p
    class="text-base sm:text-lg md:text-xl max-w-xs sm:max-w-lg md:max-w-2xl text-stone-200 hero-subtitle opacity-0"
  >
    Pihenes, nyugalom es termeszet egy helyen.
  </p>

  <a
    href="#about"
    class="mt-8 sm:mt-12 inline-flex items-center gap-2 px-6 py-3 bg-white text-stone-900 rounded-full text-sm sm:text-base font-medium hover:bg-stone-100 transition-all duration-300 hover:scale-105 hero-cta opacity-0"
  >
    Fedezd fel
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 9l-7 7-7-7"></path>
    </svg>
  </a>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg
      class="w-5 h-5 sm:w-6 sm:h-6 text-white/60"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>

<style>
  @keyframes hero-fade-in {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-title {
    animation: hero-fade-in 1s ease 0.2s forwards;
  }

  .hero-subtitle {
    animation: hero-fade-in 1s ease 0.5s forwards;
  }

  .hero-cta {
    animation: hero-fade-in 1s ease 0.8s forwards;
  }
</style>
