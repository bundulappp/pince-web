---
const galleryItems = [
  {
    src: "https://picsum.photos/800/600?random=1",
    alt: "Apartman belső",
    title: "Nappali",
    description: "Hangulatos, modern nappali terméskő falakkal",
  },
  {
    src: "https://picsum.photos/400/300?random=2",
    alt: "Konyha",
    title: "Konyha",
    description: "Teljesen felszerelt konyha minden szükséges eszközzel",
  },
  {
    src: "https://picsum.photos/400/300?random=3",
    alt: "Hálószoba",
    title: "Hálószoba",
    description: "Kényelmes franciaágyas hálószoba panorámával",
  },
  {
    src: "https://picsum.photos/400/300?random=4",
    alt: "Terasz",
    title: "Terasz",
    description: "Privát terasz kilátással a szőlőkre",
  },
  {
    src: "https://picsum.photos/400/300?random=5",
    alt: "Kert",
    title: "Kert",
    description: "Gondozott kert pihenési lehetőséggel",
  },
  {
    src: "https://picsum.photos/400/300?random=6",
    alt: "Környezet",
    title: "Környezet",
    description: "Gyönyörű természeti környezet a közelben",
  },
];
---

<section id="gallery" class="py-16 sm:py-20 md:py-24 px-4 sm:px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-12 sm:mb-16 animate-on-scroll fade-up">
      <p
        class="text-sm tracking-[0.2em] uppercase text-amber-700 mb-2 font-sans"
      >
        Képgaléria
      </p>
      <h2
        class="text-3xl sm:text-4xl md:text-5xl font-bold mb-3 sm:mb-4 text-stone-900"
      >
        Galéria
      </h2>
      <p class="text-base sm:text-lg text-stone-600">
        Pillants be az apartmanba.
      </p>
    </div>

    <!-- Desktop/Tablet Grid -->
    <div class="hidden sm:grid sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">
      {
        galleryItems.map((item, i) => (
          <div
            class:list={[
              "animate-on-scroll scale-in gallery-item cursor-pointer",
              i === 0 ? "sm:col-span-2 lg:col-span-2 lg:row-span-2" : "",
            ]}
            style={`animation-delay: ${i * 100}ms;`}
            data-gallery-index={i}
          >
            <img
              src={item.src}
              alt={item.alt}
              class:list={[
                "w-full h-full object-cover hover:scale-[1.02] transition-transform duration-500",
                i === 0 ? "aspect-[4/3] lg:aspect-auto" : "aspect-[4/3]",
              ]}
              loading="lazy"
            />
            <div class="gallery-caption">
              <h4>{item.title}</h4>
              <p>{item.description}</p>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Mobile Swipeable Gallery -->
    <div class="sm:hidden gallery-mobile-scroll" id="gallery-scroll">
      {
        galleryItems.map((item, i) => (
          <div class="gallery-item cursor-pointer" data-gallery-index={i}>
            <img
              src={item.src}
              alt={item.alt}
              class="w-full object-cover aspect-[4/3] rounded-2xl"
              loading="lazy"
            />
            <div class="gallery-caption">
              <h4>{item.title}</h4>
              <p>{item.description}</p>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Swipe indicator for mobile -->
    <div class="sm:hidden flex justify-center mt-4 gap-1.5" id="gallery-dots">
      {
        galleryItems.map((_, i) => (
          <div
            class:list={[
              "w-2 h-2 rounded-full transition-colors duration-200",
              i === 0 ? "bg-amber-700" : "bg-stone-300",
            ]}
            data-dot={i}
          />
        ))
      }
    </div>
  </div>
</section>

<!-- Lightbox -->
<div class="lightbox-overlay" id="lightbox">
  <button class="lightbox-close" id="lightbox-close" aria-label="Close">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>
  <button
    class="lightbox-nav lightbox-prev"
    id="lightbox-prev"
    aria-label="Previous"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M15 19l-7-7 7-7"></path>
    </svg>
  </button>
  <img id="lightbox-img" src="" alt="" />
  <button
    class="lightbox-nav lightbox-next"
    id="lightbox-next"
    aria-label="Next"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M9 5l7 7-7 7"></path>
    </svg>
  </button>
  <div class="lightbox-counter" id="lightbox-counter"></div>
</div>

<script>
  const galleryImages = document.querySelectorAll("[data-gallery-index]");
  const lightbox = document.getElementById("lightbox");
  const lightboxImg = document.getElementById(
    "lightbox-img",
  ) as HTMLImageElement;
  const lightboxCounter = document.getElementById("lightbox-counter");
  const lightboxClose = document.getElementById("lightbox-close");
  const lightboxPrev = document.getElementById("lightbox-prev");
  const lightboxNext = document.getElementById("lightbox-next");

  const images: string[] = [];
  galleryImages.forEach((el) => {
    const img = el.querySelector("img");
    if (img && !images.includes(img.src)) {
      images.push(img.src);
    }
  });

  let currentIndex = 0;

  function openLightbox(index: number) {
    currentIndex = index;
    updateLightbox();
    lightbox?.classList.add("active");
    document.body.style.overflow = "hidden";
  }

  function closeLightbox() {
    lightbox?.classList.remove("active");
    document.body.style.overflow = "";
  }

  function updateLightbox() {
    if (lightboxImg) lightboxImg.src = images[currentIndex];
    if (lightboxCounter)
      lightboxCounter.textContent = `${currentIndex + 1} / ${images.length}`;
  }

  function nextImage() {
    currentIndex = (currentIndex + 1) % images.length;
    updateLightbox();
  }

  function prevImage() {
    currentIndex = (currentIndex - 1 + images.length) % images.length;
    updateLightbox();
  }

  galleryImages.forEach((el) => {
    el.addEventListener("click", () => {
      const index = parseInt(el.getAttribute("data-gallery-index") || "0");
      openLightbox(index);
    });
  });

  lightboxClose?.addEventListener("click", closeLightbox);
  lightboxPrev?.addEventListener("click", prevImage);
  lightboxNext?.addEventListener("click", nextImage);

  lightbox?.addEventListener("click", (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener("keydown", (e) => {
    if (!lightbox?.classList.contains("active")) return;
    if (e.key === "Escape") closeLightbox();
    if (e.key === "ArrowRight") nextImage();
    if (e.key === "ArrowLeft") prevImage();
  });

  // Touch swipe for lightbox
  let touchStartX = 0;
  lightbox?.addEventListener("touchstart", (e) => {
    touchStartX = e.touches[0].clientX;
  });

  lightbox?.addEventListener("touchend", (e) => {
    const touchEndX = e.changedTouches[0].clientX;
    const diff = touchStartX - touchEndX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) nextImage();
      else prevImage();
    }
  });

  // Mobile gallery scroll dots
  const galleryScroll = document.getElementById("gallery-scroll");
  const dots = document.querySelectorAll("[data-dot]");

  galleryScroll?.addEventListener("scroll", () => {
    const scrollLeft = galleryScroll.scrollLeft;
    const itemWidth = galleryScroll.offsetWidth * 0.85 + 12;
    const activeIndex = Math.round(scrollLeft / itemWidth);
    dots.forEach((dot, i) => {
      dot.classList.toggle("bg-amber-700", i === activeIndex);
      dot.classList.toggle("bg-stone-300", i !== activeIndex);
    });
  });
</script>
