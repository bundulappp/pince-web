<section id="contact" class="py-16 sm:py-20 md:py-24">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="grid md:grid-cols-2 gap-8 md:gap-12">
      <div class="animate-on-scroll fade-left">
        <h2 class="text-3xl sm:text-4xl font-bold mb-4 sm:mb-6 text-stone-900">
          Kapcsolat
        </h2>
        <p class="text-base sm:text-lg text-stone-600 mb-6 sm:mb-8">
          Kerdesed van? Irj nekunk, vagy hivj minket!
        </p>

        <div class="space-y-4 sm:space-y-5">
          <div class="flex items-center gap-3 sm:gap-4">
            <div
              class="w-10 h-10 sm:w-12 sm:h-12 rounded-xl bg-amber-50 flex items-center justify-center text-amber-700 shrink-0"
            >
              <svg
                class="w-5 h-5 sm:w-6 sm:h-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <div>
              <p class="text-sm text-stone-500">Cim</p>
              <p class="text-base sm:text-lg text-stone-800">
                Balaton-felvidek, Magyarorszag
              </p>
            </div>
          </div>

          <div class="flex items-center gap-3 sm:gap-4">
            <div
              class="w-10 h-10 sm:w-12 sm:h-12 rounded-xl bg-amber-50 flex items-center justify-center text-amber-700 shrink-0"
            >
              <svg
                class="w-5 h-5 sm:w-6 sm:h-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
            </div>
            <div>
              <p class="text-sm text-stone-500">Telefon</p>
              <p class="text-base sm:text-lg text-stone-800">+36 30 123 4567</p>
            </div>
          </div>

          <div class="flex items-center gap-3 sm:gap-4">
            <div
              class="w-10 h-10 sm:w-12 sm:h-12 rounded-xl bg-amber-50 flex items-center justify-center text-amber-700 shrink-0"
            >
              <svg
                class="w-5 h-5 sm:w-6 sm:h-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
            <div>
              <p class="text-sm text-stone-500">Email</p>
              <p class="text-base sm:text-lg text-stone-800">
                info@pinceapartman.hu
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="animate-on-scroll fade-right">
        <form class="space-y-4">
          <div>
            <label
              for="name"
              class="block text-sm font-medium text-stone-700 mb-1">Nev</label
            >
            <input
              type="text"
              id="name"
              class="w-full px-4 py-3 rounded-xl border border-stone-200 focus:border-amber-300 focus:ring-2 focus:ring-amber-100 outline-none transition-all duration-200 text-sm sm:text-base"
              placeholder="Neved"
            />
          </div>
          <div>
            <label
              for="email"
              class="block text-sm font-medium text-stone-700 mb-1">Email</label
            >
            <input
              type="email"
              id="email"
              class="w-full px-4 py-3 rounded-xl border border-stone-200 focus:border-amber-300 focus:ring-2 focus:ring-amber-100 outline-none transition-all duration-200 text-sm sm:text-base"
              placeholder="email@pelda.hu"
            />
          </div>
          <div>
            <label
              for="message"
              class="block text-sm font-medium text-stone-700 mb-1"
              >Uzenet</label
            >
            <textarea
              id="message"
              rows="4"
              class="w-full px-4 py-3 rounded-xl border border-stone-200 focus:border-amber-300 focus:ring-2 focus:ring-amber-100 outline-none transition-all duration-200 resize-none text-sm sm:text-base"
              placeholder="Ird le, miben segithetunk..."></textarea>
          </div>
          <button
            type="submit"
            class="w-full py-3 px-6 bg-stone-900 text-white rounded-xl font-medium hover:bg-stone-700 active:scale-[0.98] transition-all duration-200 text-sm sm:text-base"
          >
            Uzenet kuldese
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
