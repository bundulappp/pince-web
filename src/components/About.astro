<section id="about" class="py-16 sm:py-20 md:py-24 px-4 sm:px-6">
  <div
    class="max-w-5xl mx-auto grid md:grid-cols-2 gap-8 md:gap-12 items-center"
  >
    <div class="animate-on-scroll fade-left">
      <p
        class="text-sm tracking-[0.2em] uppercase text-amber-700 mb-2 font-sans"
      >
        Rólunk
      </p>
      <h2
        class="text-3xl sm:text-4xl md:text-5xl font-bold mb-4 sm:mb-6 text-stone-900"
      >
        Ahol megáll az idő
      </h2>
      <p
        class="text-base sm:text-lg leading-7 sm:leading-8 text-stone-600 mb-4 sm:mb-6"
      >
        Felújított pinceépület, modern kényelem, vidéki hangulat.
      </p>
      <p class="text-base sm:text-lg leading-7 sm:leading-8 text-stone-600">
        Balaton-felvidék szíve, természetközelben. Csend és kikapcsolódás.
      </p>
    </div>

    <div class="animate-on-scroll fade-right delay-200">
      <div class="relative">
        <img
          src="https://picsum.photos/600/450?random=10"
          alt="Pince Apartman külső"
          class="rounded-2xl shadow-xl w-full object-cover aspect-[4/3]"
          loading="lazy"
        />
        <div
          class="absolute -bottom-4 -right-4 w-24 h-24 sm:w-32 sm:h-32 bg-amber-100 rounded-2xl -z-10"
        >
        </div>
      </div>
    </div>
  </div>
</section>
