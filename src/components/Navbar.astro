<nav id="navbar" class="fixed top-0 w-full z-50 transition-all duration-300">
  <div
    class="max-w-6xl mx-auto px-4 sm:px-6 py-4 sm:py-5 flex justify-between items-center"
  >
    <a
      href="#"
      class="font-bold text-lg sm:text-xl tracking-tight text-white navbar-link transition-colors duration-300"
    >
      Pince Apartman
    </a>

    <button
      id="menu-toggle"
      class="sm:hidden p-2 rounded-lg hover:bg-white/10 transition-colors navbar-link"
      aria-label="Menu"
    >
      <svg
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          id="menu-icon"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>

    <ul class="hidden sm:flex gap-6">
      <li>
        <a
          href="#about"
          class="navbar-link text-white/80 hover:text-white transition-colors duration-200"
          >Rolunk</a
        >
      </li>
      <li>
        <a
          href="#features"
          class="navbar-link text-white/80 hover:text-white transition-colors duration-200"
          >Szolgaltatasok</a
        >
      </li>
      <li>
        <a
          href="#gallery"
          class="navbar-link text-white/80 hover:text-white transition-colors duration-200"
          >Galeria</a
        >
      </li>
      <li>
        <a
          href="#contact"
          class="navbar-link text-white/80 hover:text-white transition-colors duration-200"
          >Kapcsolat</a
        >
      </li>
    </ul>
  </div>

  <div
    id="mobile-menu"
    class="sm:hidden hidden overflow-hidden transition-all duration-300 max-h-0"
  >
    <ul class="px-4 pb-4 space-y-2">
      <li>
        <a
          href="#about"
          class="block py-2 px-3 rounded-lg navbar-link text-white/80 hover:bg-white/10 hover:text-white transition-colors"
          >Rolunk</a
        >
      </li>
      <li>
        <a
          href="#features"
          class="block py-2 px-3 rounded-lg navbar-link text-white/80 hover:bg-white/10 hover:text-white transition-colors"
          >Szolgaltatasok</a
        >
      </li>
      <li>
        <a
          href="#gallery"
          class="block py-2 px-3 rounded-lg navbar-link text-white/80 hover:bg-white/10 hover:text-white transition-colors"
          >Galeria</a
        >
      </li>
      <li>
        <a
          href="#contact"
          class="block py-2 px-3 rounded-lg navbar-link text-white/80 hover:bg-white/10 hover:text-white transition-colors"
          >Kapcsolat</a
        >
      </li>
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");

  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    if (!menu?.classList.contains("hidden")) {
      menu.style.maxHeight = menu.scrollHeight + "px";
    } else {
      menu!.style.maxHeight = "0";
    }
  });

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      menu.style.maxHeight = "0";
    });
  });

  const navbar = document.getElementById("navbar");
  const links = document.querySelectorAll(".navbar-link");

  function updateNavbar() {
    const scrolled = window.scrollY > 50;
    if (scrolled) {
      navbar?.classList.add("bg-white", "shadow-md", "backdrop-blur-md");
      navbar?.classList.remove("py-4", "sm:py-5");
      links.forEach((link) => {
        link.classList.remove("text-white", "text-white/80");
        link.classList.add("text-stone-700");
      });
    } else {
      navbar?.classList.remove("bg-white", "shadow-md", "backdrop-blur-md");
      links.forEach((link) => {
        link.classList.remove("text-stone-700");
        link.classList.add("text-white", "text-white/80");
      });
    }
  }

  window.addEventListener("scroll", updateNavbar);
  updateNavbar();
</script>
