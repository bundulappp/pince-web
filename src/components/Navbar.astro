<nav id="navbar" class="fixed top-0 w-full z-50 transition-all duration-300">
  <div
    class="max-w-6xl mx-auto px-4 sm:px-6 py-4 sm:py-5 flex justify-between items-center"
  >
    <a
      href="#"
      class="font-bold text-lg sm:text-xl tracking-tight text-white navbar-link transition-colors duration-300"
    >
      Pince Apartman
    </a>

    <div
      id="desktop-nav"
      class="hidden md:flex gap-4 lg:gap-8 w-full justify-end relative"
    >
      <div
        id="nav-pill"
        class="absolute rounded-full transition-all duration-300 ease-out opacity-0 pointer-events-none"
      >
      </div>
      <a
        href="#about"
        class="navbar-link nav-item relative z-10 px-4 py-2 rounded-full text-white/80 transition-colors duration-200"
        >Rolunk</a
      >
      <a
        href="#features"
        class="navbar-link nav-item relative z-10 px-4 py-2 rounded-full text-white/80 transition-colors duration-200"
        >Szolgaltatasok</a
      >
      <a
        href="#gallery"
        class="navbar-link nav-item relative z-10 px-4 py-2 rounded-full text-white/80 transition-colors duration-200"
        >Galeria</a
      >
      <a
        href="#contact"
        class="navbar-link nav-item relative z-10 px-4 py-2 rounded-full text-white/80 transition-colors duration-200"
        >Kapcsolat</a
      >
    </div>

    <button
      id="menu-toggle"
      class="md:hidden p-2 rounded-lg hover:bg-white/10 transition-colors navbar-link"
      aria-label="Menu"
    >
      <svg
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          id="menu-icon"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="md:hidden hidden overflow-hidden transition-all duration-300 max-h-0"
  >
    <ul class="px-4 pb-4 space-y-2">
      <li>
        <a
          href="#about"
          class="block py-2 px-4 rounded-full navbar-link text-white/80 hover:bg-stone-800/70 hover:text-white transition-all"
          >Rolunk</a
        >
      </li>
      <li>
        <a
          href="#features"
          class="block py-2 px-4 rounded-full navbar-link text-white/80 hover:bg-stone-800/70 hover:text-white transition-all"
          >Szolgaltatasok</a
        >
      </li>
      <li>
        <a
          href="#gallery"
          class="block py-2 px-4 rounded-full navbar-link text-white/80 hover:bg-stone-800/70 hover:text-white transition-all"
          >Galeria</a
        >
      </li>
      <li>
        <a
          href="#contact"
          class="block py-2 px-4 rounded-full navbar-link text-white/80 hover:bg-stone-800/70 hover:text-white transition-all"
          >Kapcsolat</a
        >
      </li>
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");

  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    if (!menu?.classList.contains("hidden")) {
      menu.style.maxHeight = menu.scrollHeight + "px";
    } else {
      menu!.style.maxHeight = "0";
    }
  });

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      menu.style.maxHeight = "0";
    });
  });

  const navbar = document.getElementById("navbar");
  const links = document.querySelectorAll(".navbar-link");
  const desktopNav = document.getElementById("desktop-nav");
  const pill = document.getElementById("nav-pill");
  const navItems = document.querySelectorAll(".nav-item");

  let isScrolled = false;

  function updateNavbar() {
    const scrolled = window.scrollY > 50;
    isScrolled = scrolled;
    if (scrolled) {
      navbar?.classList.add("bg-amber-50/95", "shadow-md", "backdrop-blur-md");
      navbar?.classList.remove("py-4", "sm:py-5");
      links.forEach((link) => {
        link.classList.remove("text-white", "text-white/80");
        link.classList.add("text-stone-900");
      });
    } else {
      navbar?.classList.remove(
        "bg-amber-50/95",
        "shadow-md",
        "backdrop-blur-md",
      );
      links.forEach((link) => {
        link.classList.remove("text-stone-900");
        link.classList.add("text-white", "text-white/80");
      });
    }
  }

  window.addEventListener("scroll", updateNavbar);
  updateNavbar();

  // Animated pill navigation
  function movePill(target: HTMLElement) {
    if (!pill || !desktopNav) return;
    const navRect = desktopNav.getBoundingClientRect();
    const targetRect = target.getBoundingClientRect();
    pill.style.left = `${targetRect.left - navRect.left}px`;
    pill.style.top = `${targetRect.top - navRect.top}px`;
    pill.style.width = `${targetRect.width}px`;
    pill.style.height = `${targetRect.height}px`;
    pill.style.opacity = "1";

    if (isScrolled) {
      pill.style.backgroundColor = "rgb(41 37 36 / 0.8)"; // stone-800
      (target as HTMLElement).style.color = "#fffbeb"; // amber-50
    } else {
      pill.style.backgroundColor = "rgba(255,255,255,0.2)";
      (target as HTMLElement).style.color = "#ffffff";
    }
  }

  navItems.forEach((item) => {
    item.addEventListener("mouseenter", () => movePill(item as HTMLElement));
    item.addEventListener("mouseleave", () => {
      (item as HTMLElement).style.color = "";
    });
  });

  desktopNav?.addEventListener("mouseleave", () => {
    if (pill) pill.style.opacity = "0";
    navItems.forEach((item) => {
      (item as HTMLElement).style.color = "";
    });
  });
</script>
