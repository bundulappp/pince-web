<nav id="navbar" class="fixed top-0 w-full z-50 transition-all duration-300">
  <div
    class="max-w-6xl mx-auto px-4 sm:px-6 py-4 sm:py-5 flex justify-between items-center"
  >
    <a
      href="#"
      class="font-bold text-lg sm:text-xl tracking-tight text-white navbar-link transition-colors duration-300"
      style="font-family: 'Cormorant Garamond', serif; font-size: 1.5rem;"
    >
      Pince Apartman
    </a>

    <div
      id="desktop-nav"
      class="hidden md:flex gap-2 lg:gap-6 items-center relative"
    >
      <div
        id="nav-pill"
        class="absolute rounded-full transition-all duration-300 ease-out opacity-0 pointer-events-none"
      >
      </div>
      <a
        href="#about"
        class="navbar-link nav-item relative z-10 px-4 py-2 rounded-full text-white/80 transition-colors duration-200"
        >Rólunk</a
      >
      <a
        href="#features"
        class="navbar-link nav-item relative z-10 px-4 py-2 rounded-full text-white/80 transition-colors duration-200"
        >Szolgáltatások</a
      >
      <a
        href="#gallery"
        class="navbar-link nav-item relative z-10 px-4 py-2 rounded-full text-white/80 transition-colors duration-200"
        >Galéria</a
      >
      <a
        href="#pricing"
        class="navbar-link nav-item relative z-10 px-4 py-2 rounded-full text-white/80 transition-colors duration-200"
        >Árak</a
      >
      <a
        href="#contact"
        class="navbar-link nav-item relative z-10 px-4 py-2 rounded-full text-white/80 transition-colors duration-200"
        >Kapcsolat</a
      >

      <!-- Language Switcher -->
      <div class="relative ml-2" id="lang-switcher">
        <button
          class="navbar-link flex items-center gap-1 px-3 py-1.5 rounded-full text-sm text-white/80 hover:text-white transition-colors duration-200 border border-white/20 hover:border-white/40"
          id="lang-toggle"
        >
          <span id="current-lang">HU</span>
          <svg
            class="w-3 h-3"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>
        <div
          id="lang-dropdown"
          class="absolute top-full right-0 mt-2 bg-white rounded-xl shadow-lg overflow-hidden hidden min-w-[80px]"
        >
          <a
            href="#"
            class="block px-4 py-2 text-sm text-stone-700 hover:bg-amber-50 transition-colors lang-option"
            data-lang="HU">Magyar</a
          >
          <a
            href="#"
            class="block px-4 py-2 text-sm text-stone-700 hover:bg-amber-50 transition-colors lang-option"
            data-lang="EN">English</a
          >
        </div>
      </div>

      <!-- Booking CTA -->
      <a
        href="#contact"
        class="ml-3 px-5 py-2.5 bg-amber-700 text-white rounded-full text-sm font-medium hover:bg-amber-800 transition-all duration-300 hover:scale-105 shadow-md shadow-amber-900/20 nav-cta"
      >
        Foglalj most!
      </a>
    </div>

    <button
      id="menu-toggle"
      class="md:hidden p-3 rounded-lg hover:bg-white/10 transition-colors navbar-link min-w-[44px] min-h-[44px] flex items-center justify-center"
      aria-label="Menu"
    >
      <svg
        class="w-6 h-6"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          id="menu-icon"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>

  <div
    id="mobile-menu"
    class="md:hidden hidden overflow-hidden transition-all duration-300 max-h-0"
  >
    <ul class="px-4 pb-4 space-y-1">
      <li>
        <a
          href="#about"
          class="block py-3 px-4 rounded-xl navbar-link text-white/80 hover:bg-stone-800/70 hover:text-white transition-all min-h-[44px] flex items-center"
          >Rólunk</a
        >
      </li>
      <li>
        <a
          href="#features"
          class="block py-3 px-4 rounded-xl navbar-link text-white/80 hover:bg-stone-800/70 hover:text-white transition-all min-h-[44px] flex items-center"
          >Szolgáltatások</a
        >
      </li>
      <li>
        <a
          href="#gallery"
          class="block py-3 px-4 rounded-xl navbar-link text-white/80 hover:bg-stone-800/70 hover:text-white transition-all min-h-[44px] flex items-center"
          >Galéria</a
        >
      </li>
      <li>
        <a
          href="#pricing"
          class="block py-3 px-4 rounded-xl navbar-link text-white/80 hover:bg-stone-800/70 hover:text-white transition-all min-h-[44px] flex items-center"
          >Árak</a
        >
      </li>
      <li>
        <a
          href="#contact"
          class="block py-3 px-4 rounded-xl navbar-link text-white/80 hover:bg-stone-800/70 hover:text-white transition-all min-h-[44px] flex items-center"
          >Kapcsolat</a
        >
      </li>
      <li class="pt-2 flex items-center justify-between px-4">
        <div class="flex gap-2">
          <a
            href="#"
            class="px-3 py-1.5 rounded-full text-sm navbar-link text-white/60 hover:text-white border border-white/20 transition-colors mobile-lang"
            data-lang="HU">HU</a
          >
          <a
            href="#"
            class="px-3 py-1.5 rounded-full text-sm navbar-link text-white/60 hover:text-white border border-white/20 transition-colors mobile-lang"
            data-lang="EN">EN</a
          >
        </div>
      </li>
      <li class="pt-2 px-4">
        <a
          href="#contact"
          class="block text-center py-3 px-6 bg-amber-700 text-white rounded-xl font-medium hover:bg-amber-800 transition-all"
        >
          Foglalj most!
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");

  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    if (!menu?.classList.contains("hidden")) {
      menu.style.maxHeight = menu.scrollHeight + "px";
    } else {
      menu!.style.maxHeight = "0";
    }
  });

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      menu.style.maxHeight = "0";
    });
  });

  const navbar = document.getElementById("navbar");
  const links = document.querySelectorAll(".navbar-link");
  const desktopNav = document.getElementById("desktop-nav");
  const pill = document.getElementById("nav-pill");
  const navItems = document.querySelectorAll(".nav-item");

  let isScrolled = false;

  function updateNavbar() {
    const scrolled = window.scrollY > 50;
    isScrolled = scrolled;
    if (scrolled) {
      navbar?.classList.add("bg-amber-50/95", "shadow-md", "backdrop-blur-md");
      navbar?.classList.remove("py-4", "sm:py-5");
      links.forEach((link) => {
        link.classList.remove("text-white", "text-white/80");
        link.classList.add("text-stone-900");
      });
      document
        .querySelector(".nav-cta")
        ?.classList.remove("shadow-amber-900/20");
      document.querySelector(".nav-cta")?.classList.add("shadow-amber-900/10");
    } else {
      navbar?.classList.remove(
        "bg-amber-50/95",
        "shadow-md",
        "backdrop-blur-md",
      );
      links.forEach((link) => {
        link.classList.remove("text-stone-900");
        link.classList.add("text-white", "text-white/80");
      });
    }
  }

  window.addEventListener("scroll", updateNavbar);
  updateNavbar();

  // Animated pill navigation
  function movePill(target: HTMLElement) {
    if (!pill || !desktopNav) return;
    const navRect = desktopNav.getBoundingClientRect();
    const targetRect = target.getBoundingClientRect();
    pill.style.left = `${targetRect.left - navRect.left}px`;
    pill.style.top = `${targetRect.top - navRect.top}px`;
    pill.style.width = `${targetRect.width}px`;
    pill.style.height = `${targetRect.height}px`;
    pill.style.opacity = "1";

    if (isScrolled) {
      pill.style.backgroundColor = "rgb(41 37 36 / 0.8)";
      (target as HTMLElement).style.color = "#fffbeb";
    } else {
      pill.style.backgroundColor = "rgba(255,255,255,0.2)";
      (target as HTMLElement).style.color = "#ffffff";
    }
  }

  navItems.forEach((item) => {
    item.addEventListener("mouseenter", () => movePill(item as HTMLElement));
    item.addEventListener("mouseleave", () => {
      (item as HTMLElement).style.color = "";
    });
  });

  desktopNav?.addEventListener("mouseleave", () => {
    if (pill) pill.style.opacity = "0";
    navItems.forEach((item) => {
      (item as HTMLElement).style.color = "";
    });
  });

  // Language switcher
  const langToggle = document.getElementById("lang-toggle");
  const langDropdown = document.getElementById("lang-dropdown");

  langToggle?.addEventListener("click", () => {
    langDropdown?.classList.toggle("hidden");
  });

  document.addEventListener("click", (e) => {
    if (!document.getElementById("lang-switcher")?.contains(e.target as Node)) {
      langDropdown?.classList.add("hidden");
    }
  });

  document.querySelectorAll(".lang-option, .mobile-lang").forEach((el) => {
    el.addEventListener("click", (e) => {
      e.preventDefault();
      const lang = (e.currentTarget as HTMLElement).dataset.lang;
      const currentLangEl = document.getElementById("current-lang");
      if (currentLangEl && lang) currentLangEl.textContent = lang;
      langDropdown?.classList.add("hidden");
    });
  });
</script>
